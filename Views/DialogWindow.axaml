<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MultiWindowApp.ViewModels"
        x:Class="MultiWindowApp.Views.DialogWindow"
        x:DataType="vm:DialogViewModel"
        Title="Enter data"
        Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
 
    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Enter data:"
                   FontSize="16" FontWeight="Bold" />
 
        <Grid ColumnDefinitions="120,*"
              RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
 
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Name *" VerticalAlignment="Center" />
            <TextBox   Grid.Row="0" Grid.Column="1"
                       Text="{Binding Name}" Watermark="Required" />
 
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="E-mail" VerticalAlignment="Center" />
            <TextBox   Grid.Row="1" Grid.Column="1"
                       Text="{Binding Email}" Watermark="user@example.com" />
 
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Age" VerticalAlignment="Center" />
            <NumericUpDown Grid.Row="2" Grid.Column="1"
                           Value="{Binding Age}" Minimum="1" Maximum="120" />
 
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="Admin" VerticalAlignment="Center" />
            <CheckBox  Grid.Row="3" Grid.Column="1"
                       IsChecked="{Binding IsAdmin}" />
        </Grid>
 
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Accept"
                    Command="{Binding ConfirmCommand}" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
